---
import Layout from '../../layouts/Layout.astro';
import news from '../../data/news.json';
import telemetry from '../../data/telemetry.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const dateOptions: Intl.DateTimeFormatOptions = { day: 'numeric', month: 'long', year: 'numeric' };
const timeOptions: Intl.DateTimeFormatOptions = { hour: '2-digit', minute: '2-digit' };

const latestStoryDate = news.length > 0 
  ? new Date(Math.max(...news.map(n => new Date(n.date).getTime()))).toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', dateOptions)
  : '';

const lastTelemetry = telemetry[telemetry.length - 1];
const syncDate = lastTelemetry ? new Date(lastTelemetry.timestamp) : null;
const syncDisplay = syncDate 
  ? `${syncDate.toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', dateOptions)} ${syncDate.toLocaleTimeString(lang === 'pl' ? 'pl-PL' : 'en-US', timeOptions)}`
  : '';

// --- 10 HONEY THEMES (Wall + Interior Gradient) ---
const themes = [
  { wall: "#D97706", from: "#FBBF24", to: "#F59E0B" }, // 0: Amber Glow
  { wall: "#B45309", from: "#D97706", to: "#B45309" }, // 1: Deep Forest Honey
  { wall: "#F59E0B", from: "#FDE68A", to: "#FBBF24" }, // 2: Golden Pollen
  { wall: "#FBBF24", from: "#FEF3C7", to: "#FDE68A" }, // 3: Pale Nectar
  { wall: "#92400E", from: "#B45309", to: "#92400E" }, // 4: Burnt Amber
  { wall: "#FDE68A", from: "#FFFBEB", to: "#FEF3C7" }, // 5: Royal Jelly
  { wall: "#FB923C", from: "#FDBA74", to: "#FB923C" }, // 6: Sun-kissed Orange
  { wall: "#FACC15", from: "#FEF08A", to: "#FACC15" }, // 7: Bright Gold
  { wall: "#78350F", from: "#92400E", to: "#78350F" }, // 8: Dark Propolis
  { wall: "#EAB308", from: "#FDE047", to: "#EAB308" }, // 9: Summer Bloom
];

// --- GRID LOGIC (Center-Weighted News) ---
const COLS = 10;
const ROWS = 15; // Increased to ensure fill
const centerX = 5;
const centerY = 8;
const headerRow = 2;
const statsRow = 3;

// 1. Identify content positions
const contentMap = new Map();

// Headers
contentMap.set(`${headerRow},${centerX}`, { type: 'title', content: t('v4.nav.beebuzz') });
contentMap.set(`${statsRow},${centerX-1}`, { type: 'subtitle', content: t('v4.beeops.news.subtitle') });
contentMap.set(`${statsRow},${centerX}`, { type: 'stat', label: t('v4.beeops.last_update'), value: latestStoryDate });
contentMap.set(`${statsRow},${centerX+1}`, { type: 'stat', label: t('v4.beeops.data_sync'), value: syncDisplay });

// News (Sorted by distance from news center)
const newsItems = news.slice(0, 30);
const newsGridPos = [];
for (let r = 4; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    if (contentMap.has(`${r},${c}`)) continue;
    const dx = c - centerX;
    const dy = r - centerY;
    const dist = Math.sqrt(dx*dx + dy*dy);
    newsGridPos.push({ r, c, dist });
  }
}
newsGridPos.sort((a, b) => a.dist - b.dist);
newsItems.forEach((item, i) => {
  if (i < newsGridPos.length) {
    const pos = newsGridPos[i];
    contentMap.set(`${pos.r},${pos.c}`, { type: 'news', ...item });
  }
});

// Final 2D Grid Array for rendering
const hiveRows = [];
for (let r = 0; r < ROWS; r++) {
  const row = [];
  for (let c = 0; c < COLS; c++) {
    row.push({
      data: contentMap.get(`${r},${c}`) || null,
      theme: themes[Math.floor(Math.random() * 10)]
    });
  }
  hiveRows.push(row);
}
---

<Layout title={t('v4.nav.beebuzz')}>
  <section class="min-h-screen bg-[#FFFDF5] overflow-x-hidden pt-20 pb-60">
    <div class="hive-wall">
      {hiveRows.map((row, r) => (
        <div class={`hive-row ${r % 2 === 0 ? 'even' : 'odd'}`}>
          {row.map((cell) => (
            <div class="hex-unit">
              <div class="hex-border" style={`background-color: ${cell.theme.wall}`}>
                <div class="hex-interior" style={`background: linear-gradient(135deg, ${cell.theme.from}, ${cell.theme.to})`}>
                  
                  {cell.data?.type === 'title' && (
                    <h1 class="text-5xl md:text-7xl font-black text-amber-950 leading-none text-center px-12 uppercase tracking-tighter rotate-[-5deg]">
                      {cell.data.content}
                    </h1>
                  )}

                  {cell.data?.type === 'subtitle' && (
                    <p class="text-xl font-bold italic text-amber-900 text-center px-16 leading-tight">
                      {cell.data.content}
                    </p>
                  )}

                  {cell.data?.type === 'stat' && (
                    <div class="text-center px-10">
                      <span class="block text-xs font-black tracking-widest text-amber-950/40 uppercase mb-3">{cell.data.label}</span>
                      <span class="text-lg font-black text-amber-950 uppercase">{cell.data.value}</span>
                    </div>
                  )}

                  {cell.data?.type === 'news' && (
                    <div class="flex flex-col justify-between h-full py-28 px-12 text-center w-full">
                      <div class="flex flex-col gap-4">
                        <span class="text-[0.7rem] font-black tracking-[0.3em] text-amber-950/50 uppercase">[{cell.data.source}]</span>
                        <h3 class="text-xl font-black leading-tight text-amber-950 uppercase tracking-tighter line-clamp-5">{cell.data.title}</h3>
                      </div>
                      <a href={cell.data.link} target="_blank" class="text-xs font-black tracking-widest uppercase text-amber-950 border-b-4 border-amber-950/20 hover:border-amber-950 inline-block mx-auto pb-1 transition-colors">{t('v4.beeops.news.read_more')}</a>
                    </div>
                  )}

                  {!cell.data && <div class="opacity-10 text-6xl rotate-12">🐝</div>}

                </div>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  :root {
    --hex-w: 480px;
    --hex-h: 554px; /* w * 1.1547 */
    --v-overlap: 138px; /* 1/4 of height */
    --h-gap: 4px;
    --wall-thick: 15px;
  }

  .hive-wall {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 150vw;
    margin-left: -25vw;
  }

  .hive-row {
    display: flex;
    margin-bottom: calc(var(--v-overlap) * -1);
  }

  .hive-row.odd {
    transform: translateX(calc(var(--hex-w) / 2 + (var(--h-gap) / 2)));
  }

  .hex-unit {
    width: var(--hex-w);
    height: var(--hex-h);
    margin: 0 calc(var(--h-gap) / 2);
    flex-shrink: 0;
  }

  .hex-border {
    width: 100%;
    height: 100%;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    padding: var(--wall-thick);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hex-interior {
    width: 100%;
    height: 100%;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  /* Thin inner double line */
  .hex-interior::after {
    content: '';
    position: absolute;
    inset: 15px;
    border: 2px solid rgba(0,0,0,0.05);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    :root { --hex-w: 380px; --hex-h: 438px; --v-overlap: 110px; }
    .hive-wall { width: 200vw; margin-left: -50vw; }
  }

  @media (max-width: 768px) {
    :root { --hex-w: 320px; --hex-h: 370px; --v-overlap: 92px; }
    .hive-wall { width: 300vw; margin-left: -100vw; }
  }
</style>
