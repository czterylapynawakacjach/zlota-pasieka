---
import Layout from '../../layouts/Layout.astro';
import news from '../../data/news.json';
import telemetry from '../../data/telemetry.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const dateOptions: Intl.DateTimeFormatOptions = {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
};

const timeOptions: Intl.DateTimeFormatOptions = {
  hour: '2-digit',
  minute: '2-digit'
};

// 1. Latest Story Date (from news.json)
const latestStoryDate = news.length > 0 
  ? new Date(Math.max(...news.map(n => new Date(n.date).getTime()))).toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', dateOptions)
  : '';

// 2. System Sync Time (from last telemetry entry)
const lastTelemetry = telemetry[telemetry.length - 1];
const syncDate = lastTelemetry ? new Date(lastTelemetry.timestamp) : null;
const syncDisplay = syncDate 
  ? `${syncDate.toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', dateOptions)} ${syncDate.toLocaleTimeString(lang === 'pl' ? 'pl-PL' : 'en-US', timeOptions)}`
  : '';

// Prepare the cells
const displayNews = news.slice(0, 30); 
const fillerCount = 60; 

const yellowShades = [
    'from-amber-200 to-amber-300',
    'from-yellow-300 to-amber-400',
    'from-amber-400 to-amber-500',
    'from-yellow-400 to-yellow-500',
    'from-amber-50 to-amber-100',
    'from-yellow-100 to-amber-200',
];

const getRandomGradient = () => yellowShades[Math.floor(Math.random() * yellowShades.length)];
---

<Layout title={t('v4.nav.beebuzz')}>
  <section class="min-h-screen bg-[#FFFDF5] overflow-x-hidden pt-40 pb-40">
    <div class="honeycomb-container">
      
      <!-- Content Cells -->
      <div class="hex-item">
        <div class="hex-border bg-charcoal">
          <div class="hex-in bg-amber">
            <h1 class="text-4xl md:text-5xl font-black text-charcoal leading-none text-center px-8 uppercase tracking-tighter rotate-[-5deg]">
              {t('v4.nav.beebuzz')}
            </h1>
          </div>
        </div>
      </div>

      <div class="hex-item">
        <div class="hex-border bg-charcoal">
          <div class="hex-in bg-charcoal text-white">
            <p class="text-lg font-bold italic text-center px-10 leading-tight">
              {t('v4.beeops.news.subtitle')}
            </p>
          </div>
        </div>
      </div>

      <div class="hex-item">
        <div class="hex-border bg-charcoal">
          <div class="hex-in bg-white">
            <div class="text-center px-6">
              <span class="block text-[0.6rem] font-black tracking-widest text-charcoal/30 uppercase mb-2">{t('v4.beeops.last_update')}</span>
              <span class="text-sm font-black text-charcoal">{latestStoryDate}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="hex-item">
        <div class="hex-border bg-charcoal">
          <div class="hex-in bg-amber-50">
            <div class="text-center px-6">
              <span class="block text-[0.6rem] font-black tracking-widest text-charcoal/30 uppercase mb-2">{t('v4.beeops.data_sync')}</span>
              <span class="text-[0.7rem] font-black text-amber-900 italic leading-tight">{syncDisplay}</span>
            </div>
          </div>
        </div>
      </div>

      {displayNews.map((item) => (
        <div class="hex-item group">
          <div class="hex-border bg-charcoal group-hover:bg-amber-600 transition-colors duration-500">
            <div class="hex-in bg-white group-hover:bg-amber-50 transition-colors duration-500">
              <div class="flex flex-col justify-between h-full py-24 px-12 text-center relative z-10 w-full">
                <div class="flex flex-col gap-3">
                  <span class="text-[0.6rem] font-black tracking-[0.2em] text-amber-600 uppercase">
                      [{item.source}]
                  </span>
                  <h3 class="text-base font-black leading-snug text-charcoal uppercase tracking-tighter line-clamp-4">
                      {item.title}
                  </h3>
                </div>
                <a href={item.link} target="_blank" class="text-[0.7rem] font-black tracking-widest uppercase text-charcoal border-b-2 border-charcoal/20 hover:border-charcoal transition-all inline-block mx-auto pb-1">
                  {t('v4.beeops.news.read_more')}
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}

      {/* Fillers */}
      {Array.from({ length: fillerCount }).map(() => (
        <div class="hex-item opacity-40 grayscale-[0.5] hover:grayscale-0 transition-all duration-700">
          <div class="hex-border bg-charcoal/5 group-hover:bg-charcoal/20">
            <div class={`hex-in bg-gradient-to-br ${getRandomGradient()}`}></div>
          </div>
        </div>
      ))}

    </div>
  </section>
</Layout>

<style>
  .honeycomb-container {
    --s: 320px;
    --m: 4px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 100vw;
    padding: 0 50px;
  }

  .hex-item {
    width: var(--s);
    height: calc(var(--s) * 1.1547);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    margin: var(--m);
    margin-bottom: calc(var(--m) - var(--s) * 0.2885);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  /* Create the staggered honeycomb effect */
  /* This requires a fixed number of columns for pure CSS staggered logic */
  /* We'll use a container query approach to make it look "natural" across sizes */
  
  .hex-border {
    width: 100%;
    height: 100%;
    padding: 8px; /* The "thick wall" */
    background-color: #2D2D2D;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hex-in {
    width: 100%;
    height: 100%;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background-image: radial-gradient(circle at top left, rgba(255,255,255,0.2), transparent);
  }

  /* Inner double line border */
  .hex-in::after {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(0,0,0,0.1);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    pointer-events: none;
  }

  .hex-item:hover {
    transform: scale(1.05);
    z-index: 50;
  }

  h1 { text-shadow: 2px 2px 0px rgba(0,0,0,0.05); }

  @media (max-width: 768px) {
    .honeycomb-container {
        padding: 0 10px;
    }
    .hex-item {
        width: 280px;
        height: calc(280px * 1.1547);
        margin-bottom: -70px;
    }
  }
</style>
