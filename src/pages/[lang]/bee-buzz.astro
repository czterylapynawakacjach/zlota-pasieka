---
import Layout from '../../layouts/Layout.astro';
import DailyBuzz from '../../components/DailyBuzz.astro';
import news from '../../data/news.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get the most recent date from news.json
const lastUpdate = news.length > 0 
  ? new Date(Math.max(...news.map(n => new Date(n.date).getTime()))).toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', {
      day: 'numeric',
      month: 'long',
      year: 'numeric'
    })
  : '';
---

<Layout title={t('v4.nav.beebuzz')}>
  <section class="py-40 bg-white min-h-screen overflow-hidden relative">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <h1 class="text-5xl sm:text-7xl md:text-8xl font-black text-charcoal tracking-tighter uppercase mb-8 leading-none">{t('v4.nav.beebuzz')}</h1>
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-12">
        <p class="text-xl text-charcoal/60 font-bold max-w-xl italic border-l-4 border-amber pl-6">{t('v4.beeops.news.subtitle')}</p>
        {lastUpdate && (
          <div class="text-[0.6rem] font-black tracking-[0.2em] text-charcoal/30 uppercase">
            {t('v4.beeops.last_update')} <span class="text-amber-600">{lastUpdate}</span>
          </div>
        )}
      </div>
      
      <DailyBuzz showHeader={false} />
    </div>

    <!-- Background Decor -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-amber/5 -skew-x-12 transform origin-top pointer-events-none"></div>
  </section>
</Layout>
