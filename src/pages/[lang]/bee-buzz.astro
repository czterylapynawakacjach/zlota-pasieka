---
import Layout from '../../layouts/Layout.astro';
import news from '../../data/news.json';
import telemetry from '../../data/telemetry.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const dateOptions: Intl.DateTimeFormatOptions = {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
};

const timeOptions: Intl.DateTimeFormatOptions = {
  hour: '2-digit',
  minute: '2-digit'
};

// 1. Latest Story Date (from news.json)
const latestStoryDate = news.length > 0 
  ? new Date(Math.max(...news.map(n => new Date(n.date).getTime()))).toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', dateOptions)
  : '';

// 2. System Sync Time (from last telemetry entry)
const lastTelemetry = telemetry[telemetry.length - 1];
const syncDate = lastTelemetry ? new Date(lastTelemetry.timestamp) : null;
const syncDisplay = syncDate 
  ? `${syncDate.toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', dateOptions)} ${syncDate.toLocaleTimeString(lang === 'pl' ? 'pl-PL' : 'en-US', timeOptions)}`
  : '';

// Prepare the cells
// We'll mix news items with some empty cells
const displayNews = news.slice(0, 15);
---

<Layout title={t('v4.nav.beebuzz')}>
  <section class="py-40 bg-white min-h-screen overflow-hidden">
    <div class="max-w-[1600px] mx-auto px-6">
      <div class="honeycomb-container">
        
        <!-- Row 1: Title and Header Info -->
        <div class="hex-cell main-title">
          <div class="hex-inner bg-amber">
            <h1 class="text-4xl font-black text-charcoal leading-none text-center px-8 uppercase tracking-tighter">
              {t('v4.nav.beebuzz')}
            </h1>
          </div>
        </div>

        <div class="hex-cell">
          <div class="hex-inner bg-charcoal text-white">
            <p class="text-sm font-bold italic text-center px-10 leading-tight">
              {t('v4.beeops.news.subtitle')}
            </p>
          </div>
        </div>

        <div class="hex-cell">
          <div class="hex-inner border-4 border-amber">
            <div class="text-center px-6">
              <span class="block text-[0.6rem] font-black tracking-widest text-charcoal/30 uppercase mb-2">{t('v4.beeops.last_update')}</span>
              <span class="text-xs font-black text-charcoal">{latestStoryDate}</span>
            </div>
          </div>
        </div>

        <div class="hex-cell hidden md:block">
            <div class="hex-inner opacity-5 bg-charcoal"></div>
        </div>

        <div class="hex-cell">
            <div class="hex-inner border-4 border-charcoal bg-amber/10">
              <div class="text-center px-6">
                <span class="block text-[0.6rem] font-black tracking-widest text-charcoal/30 uppercase mb-2">{t('v4.beeops.data_sync')}</span>
                <span class="text-[0.65rem] font-black text-amber-700 italic">{syncDisplay}</span>
              </div>
            </div>
        </div>

        <!-- News Cells -->
        {displayNews.map((item, i) => (
          <>
            {/* Inject random empty cells for organic feel */}
            {i % 4 === 0 && <div class="hex-cell hidden lg:block"><div class="hex-inner opacity-5 bg-charcoal"></div></div>}
            
            <div class="hex-cell group">
              <div class="hex-inner bg-white border-4 border-charcoal group-hover:bg-amber transition-colors duration-500">
                <div class="flex flex-col justify-between h-full py-16 px-10 text-center relative z-10">
                  <div class="flex flex-col gap-2">
                    <span class="text-[0.5rem] font-black tracking-[0.2em] text-charcoal/40 uppercase">
                        [{item.source}]
                    </span>
                    <h3 class="text-sm font-black leading-tight text-charcoal group-hover:text-charcoal uppercase tracking-tighter line-clamp-4">
                        {item.title}
                    </h3>
                  </div>
                  
                  <a 
                    href={item.link} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="text-[0.6rem] font-black tracking-widest uppercase text-amber-700 group-hover:text-charcoal underline underline-offset-4"
                  >
                    {t('v4.beeops.news.read_more')}
                  </a>
                </div>
              </div>
            </div>
          </>
        ))}

        {/* Closing filler */}
        <div class="hex-cell"><div class="hex-inner opacity-10 bg-amber"></div></div>
        <div class="hex-cell hidden md:block"><div class="hex-inner opacity-5 bg-charcoal"></div></div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .honeycomb-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    padding-bottom: 200px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .hex-cell {
    width: 300px;
    height: 346px;
    margin: -44px 2px; /* Vertical overlap */
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    flex-shrink: 0;
  }

  .hex-cell:hover {
    z-index: 50;
    transform: scale(1.1) rotate(2deg);
  }

  .hex-inner {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Specific spacing to create the "honeycomb" offset effect */
  /* This varies by screen size for responsive flow */
  @media (min-width: 1024px) {
    .honeycomb-container {
        padding-left: 155px; /* Offset every other logical row */
    }
  }

  .main-title h1 {
    transform: rotate(-5deg);
  }
</style>
