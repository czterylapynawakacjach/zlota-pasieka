---
import Layout from '../../layouts/Layout.astro';
import news from '../../data/news.json';
import telemetry from '../../data/telemetry.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const dateOptions: Intl.DateTimeFormatOptions = {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
};

const timeOptions: Intl.DateTimeFormatOptions = {
  hour: '2-digit',
  minute: '2-digit'
};

// 1. Latest Story Date (from news.json)
const latestStoryDate = news.length > 0 
  ? new Date(Math.max(...news.map(n => new Date(n.date).getTime()))).toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', dateOptions)
  : '';

// 2. System Sync Time (from last telemetry entry)
const lastTelemetry = telemetry[telemetry.length - 1];
const syncDate = lastTelemetry ? new Date(lastTelemetry.timestamp) : null;
const syncDisplay = syncDate 
  ? `${syncDate.toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', dateOptions)} ${syncDate.toLocaleTimeString(lang === 'pl' ? 'pl-PL' : 'en-US', timeOptions)}`
  : '';

// 3. Honeycomb Grid Logic
// We want a large grid where content is centered.
const ROWS = 8;
const COLS = 8;
const totalCells = ROWS * COLS;
const centerX = (COLS - 1) / 2;
const centerY = (ROWS - 1) / 2;

// Prepare content items
const contentItems = [
  { type: 'title', content: t('v4.nav.beebuzz') },
  { type: 'subtitle', content: t('v4.beeops.news.subtitle') },
  { type: 'stat', label: t('v4.beeops.last_update'), value: latestStoryDate },
  { type: 'stat', label: t('v4.beeops.data_sync'), value: syncDisplay, highlight: true },
  ...news.slice(0, 15).map(item => ({ type: 'news', ...item }))
];

// Create a flat array of cell positions with distance from center
const gridPositions = [];
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; r < ROWS && c < COLS; c++) {
    // Offset for hex layout: every odd row is shifted
    const posX = c + (r % 2 === 0 ? 0 : 0.5);
    const posY = r * 0.75; // Approx vertical compression for hex tiling
    const dist = Math.sqrt(Math.pow(posX - centerX, 2) + Math.pow(r - centerY, 2));
    gridPositions.push({ r, c, dist });
  }
}

// Sort positions by distance from center
gridPositions.sort((a, b) => a.dist - b.dist);

// Assign content to positions
const grid = gridPositions.map((pos, index) => {
  return {
    ...pos,
    data: contentItems[index] || null, // Fill with content if available, else null
    pattern: Math.floor(Math.random() * 4) // 0-3 random patterns
  };
});

// Final display needs to be sorted back to row/col for easy rendering in CSS Grid
grid.sort((a, b) => (a.r * COLS + a.c) - (b.r * COLS + b.c));

const patterns = [
    "bg-amber-400 border-amber-600 shadow-amber-200", // Pattern 0: Classic Honey
    "bg-yellow-300 border-yellow-500 shadow-yellow-100", // Pattern 1: Bright Pollen
    "bg-orange-400 border-orange-600 shadow-orange-200", // Pattern 2: Deep Nectar
    "bg-amber-50 border-amber-200 shadow-white",        // Pattern 3: Royal Jelly
];
---

<Layout title={t('v4.nav.beebuzz')}>
  <section class="min-h-screen bg-amber-50 overflow-x-hidden pt-20 pb-40">
    <div class="hive-container">
      {grid.map((cell) => (
        <div class={`hex-cell row-${cell.r} col-${cell.c} ${cell.r % 2 === 0 ? 'even-row' : 'odd-row'}`}>
          <div class={`hex-wall-yellow pattern-${cell.pattern}`}>
            <div class={`hex-inner-yellow pattern-${cell.pattern}`}>
              
              {cell.data?.type === 'title' && (
                <h1 class="text-3xl md:text-5xl font-black text-amber-900 leading-none text-center px-8 uppercase tracking-tighter rotate-[-5deg]">
                  {cell.data.content}
                </h1>
              )}

              {cell.data?.type === 'subtitle' && (
                <p class="text-sm md:text-base font-bold italic text-amber-800 text-center px-10 leading-tight">
                  {cell.data.content}
                </p>
              )}

              {cell.data?.type === 'stat' && (
                <div class="text-center px-6">
                  <span class="block text-[0.6rem] font-black tracking-widest text-amber-900/40 uppercase mb-2">{cell.data.label}</span>
                  <span class={`text-[0.65rem] md:text-xs font-black uppercase ${cell.data.highlight ? 'text-orange-700 italic' : 'text-amber-900'}`}>
                    {cell.data.value}
                  </span>
                </div>
              )}

              {cell.data?.type === 'news' && (
                <div class="flex flex-col justify-between h-full py-20 px-8 text-center relative z-10 w-full">
                  <div class="flex flex-col gap-2">
                    <span class="text-[0.5rem] font-black tracking-[0.2em] text-orange-700/60 uppercase">
                        [{cell.data.source}]
                    </span>
                    <h3 class="text-[0.7rem] md:text-[0.8rem] font-black leading-tight text-amber-950 uppercase tracking-tighter line-clamp-5">
                        {cell.data.title}
                    </h3>
                  </div>
                  <a href={cell.data.link} target="_blank" class="text-[0.6rem] font-black tracking-widest uppercase text-orange-800 border-b-2 border-orange-800/20 hover:border-orange-800 transition-all inline-block mx-auto pb-1">
                    {t('v4.beeops.news.read_more')}
                  </a>
                </div>
              )}

              {/* Decorative faint pattern for empty cells */}
              {!cell.data && (
                <div class="opacity-10 text-4xl rotate-12 select-none">🐝</div>
              )}

            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  :root {
    --hex-w: 320px;
    --hex-h: 370px; /* w * 1.1547 */
  }

  .hive-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    width: 130vw; /* Spill over for artistic feel */
    margin-left: -15vw;
    gap: 4px;
    padding: 20px 0;
  }

  .hex-cell {
    width: var(--hex-w);
    height: var(--hex-h);
    margin-bottom: -92px; /* 1/4 of height for interlocking */
    position: relative;
    flex-shrink: 0;
  }

  /* Staggering rows */
  .odd-row {
    transform: translateX(calc(var(--hex-w) / 2 + 2px));
  }

  .hex-wall-yellow {
    width: 100%;
    height: 100%;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    padding: 6px; /* Thick wall */
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.5s ease;
  }

  .hex-inner-yellow {
    width: 100%;
    height: 100%;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  /* Double line effect using pseudo element */
  .hex-inner-yellow::after {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(0,0,0,0.05);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    pointer-events: none;
  }

  /* Theme Patterns */
  .pattern-0.hex-wall-yellow { @apply bg-amber-600; }
  .pattern-0.hex-inner-yellow { @apply bg-amber-400; }
  
  .pattern-1.hex-wall-yellow { @apply bg-yellow-500; }
  .pattern-1.hex-inner-yellow { @apply bg-yellow-300; }
  
  .pattern-2.hex-wall-yellow { @apply bg-orange-500; }
  .pattern-2.hex-inner-yellow { @apply bg-orange-400; }
  
  .pattern-3.hex-wall-yellow { @apply bg-amber-200; }
  .pattern-3.hex-inner-yellow { @apply bg-amber-50; }

  /* Interactive scale (no twist) */
  .hex-cell:hover {
    z-index: 50;
    transform: scale(1.08);
  }

  /* Ensure rows are tight */
  .even-row, .odd-row {
    margin-right: -2px;
  }

  @media (max-width: 768px) {
    :root {
        --hex-w: 240px;
        --hex-h: 277px;
    }
    .hex-cell {
        margin-bottom: -69px;
    }
    .hive-container {
        width: 180vw;
        margin-left: -40vw;
    }
  }
</style>
